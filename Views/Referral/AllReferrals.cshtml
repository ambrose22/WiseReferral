@model ReferralTracker.Models.ViewModels.ReferralFilterViewModel

@{
    ViewData["Title"] = "All Referrals";
    var talentTeamUsers = ViewData["TalentTeamUsers"] as IEnumerable<ReferralTracker.Models.ApplicationUser>;
}

<h2 class="mb-3">All Referrals</h2>

<div class="filter-bar mb-3">
    <form method="get" asp-action="AllReferrals" class="row g-2 align-items-end">
        <div class="col-md-3">
            <label class="form-label form-label-sm">Search</label>
            <input type="text" name="search" value="@Model.Search" class="form-control form-control-sm" placeholder="Candidate name or email..." />
        </div>
        <div class="col-md-2">
            <label class="form-label form-label-sm">Status</label>
            <select name="status" class="form-select form-select-sm">
                <option value="">All Statuses</option>
                @foreach (var s in Enum.GetValues<ReferralTracker.Models.ReferralStatus>())
                {
                    <option value="@s" selected="@(Model.Status == s)">@s</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label form-label-sm">Location</label>
            <select name="location" class="form-select form-select-sm">
                <option value="">All Locations</option>
                @foreach (var loc in ReferralTracker.Models.ViewModels.ReferralViewModel.Locations)
                {
                    <option value="@loc" selected="@(Model.Location == loc)">@loc</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label form-label-sm">Assigned To</label>
            <select name="assignedTo" class="form-select form-select-sm">
                <option value="">All Recruiters</option>
                @if (talentTeamUsers != null)
                {
                    @foreach (var user in talentTeamUsers)
                    {
                        <option value="@user.Id" selected="@(Model.AssignedTo == user.Id)">@(user.FullName ?? user.Email)</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2 d-flex gap-2">
            <button type="submit" class="btn btn-sm btn-primary">Filter</button>
            @if (Model.HasActiveFilters)
            {
                <a asp-action="AllReferrals" class="btn btn-sm btn-outline-secondary">Clear</a>
            }
        </div>
    </form>
</div>

@if (!Model.Results.Any())
{
    @if (Model.HasActiveFilters)
    {
        <div class="alert alert-warning">
            No referrals match your filters. <a asp-action="AllReferrals">Clear filters</a> to see all referrals.
        </div>
    }
    else
    {
        <div class="alert alert-info">No referrals have been submitted yet.</div>
    }
}
else
{
    <div class="content-card">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Candidate Name</th>
                    <th>Location</th>
                    <th>Referred By</th>
                    <th>Assigned To</th>
                    <th>Status</th>
                    <th>Date Submitted</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Results)
                {
                    var badgeClass = r.Status switch
                    {
                        ReferralTracker.Models.ReferralStatus.Hired => "badge-hired",
                        ReferralTracker.Models.ReferralStatus.Declined => "badge-declined",
                        ReferralTracker.Models.ReferralStatus.Interviewing => "badge-interviewing",
                        ReferralTracker.Models.ReferralStatus.Screening => "badge-screening",
                        ReferralTracker.Models.ReferralStatus.MoreInfoRequested => "badge-moreinfo",
                        _ => "badge-submitted"
                    };
                    <tr>
                        <td>@r.CandidateFirstName @r.CandidateLastName</td>
                        <td>@r.Location</td>
                        <td>@r.ReferredByUser?.Email</td>
                        <td>@(r.AssignedToUser?.Email ?? "Unassigned")</td>
                        <td><span class="badge @badgeClass">@r.Status</span></td>
                        <td>@r.CreatedUtc.ToString("dd MMM yyyy")</td>
                        <td><a asp-action="Details" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary">View</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
