@model ReferralTracker.Models.Referral
@using ReferralTracker.Services.Implementations

@{
    ViewData["Title"] = "Referral Details";

    var currentUserRole = ViewData["CurrentUserRole"] as string ?? "Employee";
    var currentUserId = ViewData["CurrentUserId"] as string;
    var talentTeamUsers = ViewData["TalentTeamUsers"] as IEnumerable<ReferralTracker.Models.ApplicationUser>;

    var statusBadgeClass = Model.Status switch
    {
        ReferralTracker.Models.ReferralStatus.Hired => "badge-hired",
        ReferralTracker.Models.ReferralStatus.Declined => "badge-declined",
        ReferralTracker.Models.ReferralStatus.Interviewing => "badge-interviewing",
        ReferralTracker.Models.ReferralStatus.Screening => "badge-screening",
        ReferralTracker.Models.ReferralStatus.MoreInfoRequested => "badge-moreinfo",
        _ => "badge-submitted"
    };

    var validNextStatuses = ReferralService.GetValidNextStatuses(Model.Status);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Referral Details</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to My Referrals</a>
</div>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <strong>@Model.CandidateFirstName @Model.CandidateLastName</strong>
        <span class="badge @statusBadgeClass">@Model.Status</span>
    </div>
    <div class="card-body">
        <div class="row mb-2">
            <div class="col-md-6">
                <strong>Email:</strong> @Model.CandidateEmail
            </div>
            <div class="col-md-6">
                <strong>Phone:</strong> @(Model.CandidatePhone ?? "N/A")
            </div>
        </div>
        <div class="row mb-2">
            <div class="col-md-6">
                <strong>LinkedIn:</strong>
                @if (!string.IsNullOrEmpty(Model.CandidateLinkedIn))
                {
                    <a href="@Model.CandidateLinkedIn" target="_blank">@Model.CandidateLinkedIn</a>
                }
                else
                {
                    <span>N/A</span>
                }
            </div>
            <div class="col-md-6">
                <strong>Location:</strong> @Model.Location
            </div>
        </div>
        <div class="row mb-2">
            <div class="col-md-6">
                <strong>Referred By:</strong> @Model.ReferredByUser?.Email
            </div>
            <div class="col-md-6">
                <strong>Resume:</strong>
                @if (!string.IsNullOrEmpty(Model.ResumeFileName))
                {
                    <a asp-action="DownloadResume" asp-route-id="@Model.Id">@Model.ResumeFileName</a>
                }
                else
                {
                    <span>None uploaded</span>
                }
            </div>
        </div>
        <div class="row mb-2">
            <div class="col-md-6">
                <strong>Assigned To:</strong> @(Model.AssignedToUser?.Email ?? "Unassigned")
            </div>
            <div class="col-md-6">
                <strong>Submitted:</strong> @Model.CreatedUtc.ToString("dd MMM yyyy HH:mm")
            </div>
        </div>
        <div class="row mb-2">
            <div class="col-md-12">
                <strong>Relationship:</strong> @Model.Relationship
            </div>
        </div>
        <div class="row mb-2">
            <div class="col-md-12">
                <strong>Justification:</strong>
                <p class="mb-0">@Model.Justification</p>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(Model.DeclineReason))
        {
            <div class="row mb-2">
                <div class="col-md-12">
                    <strong>Decline Reason:</strong>
                    <p class="mb-0 text-danger">@Model.DeclineReason</p>
                </div>
            </div>
        }
    </div>
</div>

<div class="d-flex align-items-center mb-3">
    <strong class="me-2 fs-5">Current Status:</strong>
    <span class="badge @statusBadgeClass fs-5 px-3 py-2">@Model.Status</span>
</div>

@if (Model.Status == ReferralTracker.Models.ReferralStatus.MoreInfoRequested && Model.ReferredByUserId == currentUserId)
{
    var latestRequest = Model.Comments?
        .Where(c => c.Action == "MoreInfoRequested")
        .OrderByDescending(c => c.CreatedUtc)
        .FirstOrDefault();

    <div class="alert alert-warning mb-4">
        <h5 class="alert-heading">More information has been requested</h5>
        @if (latestRequest != null)
        {
            <p class="mb-0">@latestRequest.Comment</p>
            <small class="text-muted">— @latestRequest.User?.Email, @latestRequest.CreatedUtc.ToString("dd MMM yyyy HH:mm")</small>
        }
    </div>

    <div class="card mb-4">
        <div class="card-header"><strong>Respond</strong></div>
        <div class="card-body">
            <form asp-action="RespondToMoreInfo" method="post" enctype="multipart/form-data">
                <input type="hidden" name="referralId" value="@Model.Id" />
                <div class="mb-3">
                    <label for="responseText" class="form-label">Your Response</label>
                    <textarea name="responseText" id="responseText" class="form-control" rows="4" required placeholder="Provide the requested information..."></textarea>
                </div>
                <div class="mb-3">
                    <label for="resume" class="form-label">Upload New Resume (optional, PDF or DOCX)</label>
                    <input type="file" name="resume" id="resume" class="form-control" accept=".pdf,.docx" />
                </div>
                <button type="submit" class="btn btn-primary">Submit Response</button>
            </form>
        </div>
    </div>
}

@if (currentUserRole == "Admin")
{
    <div class="card mb-4">
        <div class="card-header"><strong>Actions</strong></div>
        <div class="card-body">
            @if (Model.Status == ReferralTracker.Models.ReferralStatus.Submitted)
            {
                <h6>Assign To</h6>
                <form asp-action="AssignTo" method="post" class="mb-3">
                    <input type="hidden" name="referralId" value="@Model.Id" />
                    <div class="row align-items-end">
                        <div class="col-md-6 mb-3">
                            <select name="assignToUserId" class="form-select">
                                <option value="">-- Select a recruiter --</option>
                                @if (talentTeamUsers != null)
                                {
                                    @foreach (var user in talentTeamUsers)
                                    {
                                        <option value="@user.Id">@user.FullName (@user.Email)</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <button type="submit" class="btn btn-outline-primary">Assign</button>
                        </div>
                    </div>
                </form>
            }
            else if (validNextStatuses.Length > 0)
            {
                <h6>Change Status</h6>
                <form asp-action="ChangeStatus" method="post">
                    <input type="hidden" name="referralId" value="@Model.Id" />
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="newStatus" class="form-label">New Status</label>
                            <select name="newStatus" id="newStatus" class="form-select">
                                @foreach (var status in validNextStatuses)
                                {
                                    <option value="@status">@status</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-8 mb-3">
                            <label for="notes" class="form-label">Notes</label>
                            <textarea name="notes" id="notes" class="form-control" rows="2" placeholder="Required for Declined, optional otherwise"></textarea>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">Update Status</button>
                </form>
            }
            else
            {
                <p class="text-muted">No further status transitions available.</p>
            }
        </div>
    </div>
}
else if (currentUserRole == "TalentTeam" && Model.AssignedToUserId == currentUserId)
{
    <div class="card mb-4">
        <div class="card-header"><strong>Actions</strong></div>
        <div class="card-body">
            @if (validNextStatuses.Length > 0)
            {
                <h6>Change Status</h6>
                <form asp-action="ChangeStatus" method="post">
                    <input type="hidden" name="referralId" value="@Model.Id" />
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label for="newStatus" class="form-label">New Status</label>
                            <select name="newStatus" id="newStatus" class="form-select">
                                @foreach (var status in validNextStatuses)
                                {
                                    <option value="@status">@status</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-8 mb-3">
                            <label for="notes" class="form-label">Notes</label>
                            <textarea name="notes" id="notes" class="form-control" rows="2" placeholder="Required for Declined, optional otherwise"></textarea>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">Update Status</button>
                </form>
            }
            else
            {
                <p class="text-muted">No further status transitions available.</p>
            }
        </div>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<h4>Activity Timeline</h4>
<hr />

@if (Model.Comments == null || !Model.Comments.Any())
{
    <p class="text-muted">No activity recorded yet.</p>
}
else
{
    <div class="list-group">
        @foreach (var comment in Model.Comments.OrderBy(c => c.CreatedUtc))
        {
            var actionBadgeClass = comment.Action switch
            {
                "Submitted" => "badge-submitted",
                "Assigned" => "badge-screening",
                "Responded" => "badge-responded",
                "Screening" => "badge-screening",
                "MoreInfoRequested" => "badge-moreinfo",
                "Interviewing" => "badge-interviewing",
                "Hired" => "badge-hired",
                "Declined" => "badge-declined",
                _ => "badge-submitted"
            };
            <div class="list-group-item">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <span class="badge @actionBadgeClass me-2">@comment.Action</span>
                        <small class="text-muted">@comment.User?.Email</small>
                    </div>
                    <small class="text-muted">@comment.CreatedUtc.ToString("dd MMM yyyy HH:mm")</small>
                </div>
                <p class="mb-0 mt-1">@comment.Comment</p>
            </div>
        }
    </div>
}
